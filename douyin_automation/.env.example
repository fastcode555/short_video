# ============================================================
# 抖音带货自动化系统 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值，.env 文件不应提交到版本控制
# ============================================================

# ── 数据库配置 ────────────────────────────────────────────────
# 开发环境（SQLite，默认值，无需修改）
DATABASE_URL=sqlite:///./douyin_automation.db

# 生产环境（PostgreSQL，取消注释并填写实际连接信息）
# DATABASE_URL=postgresql://用户名:密码@主机:5432/数据库名
# 示例：DATABASE_URL=postgresql://admin:secret@localhost:5432/douyin_prod

# 是否打印 SQL 语句（调试用，生产环境建议设为 false）
DB_ECHO=false

# ── Redis / Celery 配置 ───────────────────────────────────────
# Celery 消息代理地址
CELERY_BROKER_URL=redis://localhost:6379/0
# Celery 结果后端地址
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── AI 服务配置 ───────────────────────────────────────────────
# OpenAI API Key（文案生成）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OpenAI 模型名称（默认 gpt-4o）
OPENAI_MODEL=gpt-4o

# Stable Diffusion API 地址（图像重绘，本地部署时使用）
# SD_API_URL=http://localhost:7860

# ── 素材存储配置 ──────────────────────────────────────────────
# 素材文件存储根目录（图片和视频将按 product_id 分目录存放）
MATERIALS_DIR=./data/materials
# 生成视频存储目录
VIDEOS_DIR=./data/videos

# ── 抖音平台配置 ──────────────────────────────────────────────
# 抖音 Cookie（用于维持登录态，从浏览器开发者工具获取）
DOUYIN_COOKIE=

# 抖音开放平台 App Key（使用官方 API 时填写）
# DOUYIN_APP_KEY=
# DOUYIN_APP_SECRET=

# ── 告警通知配置 ──────────────────────────────────────────────
# 告警邮件地址（模块连续失败 ≥5 次时发送通知）
ALERT_EMAIL=

# Webhook 地址（支持企业微信、钉钉、飞书等）
ALERT_WEBHOOK=

# ── 调度配置 ──────────────────────────────────────────────────
# 每日自动发布时间（逗号分隔，24小时制，时区为 Asia/Shanghai）
PUBLISH_TIMES=10:00,18:00,21:00

# ── 日志配置 ──────────────────────────────────────────────────
# 日志级别：DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
